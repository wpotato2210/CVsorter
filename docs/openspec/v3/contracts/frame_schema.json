{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "msg_id": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string"
    },
    "payload": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "crc": {
      "type": "string",
      "pattern": "^[A-F0-9]{8}$"
    }
  },
  "required": [
    "msg_id",
    "command",
    "payload",
    "crc"
  ],
  "$comment": "Single source policy: contracts/frame_schema.json is authoritative; docs/openspec/v3/contracts/frame_schema.json must stay byte-identical via tools/protocol_static_guard.py."
}
