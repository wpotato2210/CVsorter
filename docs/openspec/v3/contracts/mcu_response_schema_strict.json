{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "msg_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "ACK",
        "NACK"
      ]
    },
    "nack_code": {
      "type": "integer",
      "minimum": 1,
      "maximum": 8
    },
    "detail": {
      "type": "string"
    },
    "queue_depth": {
      "type": "integer",
      "minimum": 0
    },
    "queue_cleared": {
      "type": "boolean"
    },
    "mode": {
      "type": "string",
      "enum": [
        "AUTO",
        "MANUAL",
        "SAFE"
      ]
    },
    "scheduler_state": {
      "type": "string",
      "enum": [
        "IDLE",
        "ACTIVE"
      ]
    },
    "link_state": {
      "type": "string",
      "enum": [
        "DISCONNECTED",
        "SYNCING",
        "READY",
        "DEGRADED"
      ]
    }
  },
  "required": [
    "msg_id",
    "status"
  ],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "ACK"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "mode",
          "queue_depth",
          "scheduler_state",
          "queue_cleared"
        ],
        "not": {
          "required": [
            "nack_code"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "NACK"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "nack_code"
        ],
        "not": {
          "anyOf": [
            {
              "required": [
                "mode"
              ]
            },
            {
              "required": [
                "queue_depth"
              ]
            },
            {
              "required": [
                "scheduler_state"
              ]
            },
            {
              "required": [
                "queue_cleared"
              ]
            }
          ]
        }
      }
    }
  ],
  "$comment": "Single source policy: contracts/mcu_response_schema_strict.json is authoritative; docs/openspec/v3/contracts/mcu_response_schema_strict.json must stay byte-identical via tools/protocol_static_guard.py."
}
