{
  "wire_format": {
    "frame": "<msg_id|CMD|payload|CRC32>",
    "delimiter": "|",
    "payload_delimiter": ",",
    "start_token": "<",
    "end_token": ">",
    "encoding": "ascii"
  },
  "startup": {
    "required_handshake": [
      "HELLO",
      "HEARTBEAT"
    ],
    "protocol_version": "3.1",
    "capabilities": [
      "SCHED",
      "HEARTBEAT",
      "DEDUPE",
      "CRC32"
    ]
  },
  "commands": [
    {
      "name": "HELLO",
      "args": [
        {
          "name": "version",
          "type": "string"
        },
        {
          "name": "capabilities",
          "type": "csv"
        }
      ]
    },
    {
      "name": "HEARTBEAT",
      "args": []
    },
    {
      "name": "SET_MODE",
      "args": [
        {
          "name": "mode",
          "type": "enum",
          "allowed": [
            "AUTO",
            "MANUAL",
            "SAFE"
          ]
        }
      ]
    },
    {
      "name": "SCHED",
      "args": [
        {
          "name": "lane",
          "type": "int",
          "min": 0,
          "max": 21
        },
        {
          "name": "trigger_mm",
          "type": "float",
          "min": 0.0,
          "max": 2000.0,
          "precision_dp": 3
        }
      ]
    },
    {
      "name": "GET_STATE",
      "args": []
    },
    {
      "name": "RESET_QUEUE",
      "args": []
    }
  ],
  "link_state_fsm": [
    "DISCONNECTED",
    "SYNCING",
    "READY",
    "DEGRADED"
  ],
  "ack_nack": {
    "ack_token": "ACK",
    "nack_token": "NACK",
    "nack_codes": {
      "1": "UNKNOWN_COMMAND",
      "2": "ARG_COUNT_MISMATCH",
      "3": "ARG_RANGE_ERROR",
      "4": "ARG_TYPE_ERROR",
      "5": "INVALID_MODE_TRANSITION",
      "6": "QUEUE_FULL",
      "7": "BUSY",
      "8": "MALFORMED_FRAME"
    }
  }
}
