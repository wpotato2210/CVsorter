{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "msg_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "ACK",
        "NACK"
      ]
    },
    "nack_code": {
      "type": "integer",
      "minimum": 1,
      "maximum": 8
    },
    "detail": {
      "type": "string"
    },
    "queue_depth": {
      "type": "integer",
      "minimum": 0
    },
    "queue_cleared": {
      "type": "boolean"
    },
    "mode": {
      "type": "string",
      "enum": [
        "AUTO",
        "MANUAL",
        "SAFE"
      ]
    },
    "scheduler_state": {
      "type": "string",
      "enum": [
        "IDLE",
        "ACTIVE"
      ]
    },
    "link_state": {
      "type": "string",
      "enum": [
        "DISCONNECTED",
        "SYNCING",
        "READY",
        "DEGRADED"
      ]
    }
  },
  "required": [
    "msg_id",
    "status"
  ]
}
